@model LTWeb_DinhNgocNang_2280602045.Models.Order

@{
    ViewData["Title"] = "Hóa đơn";
}

<div class="container mt-5">
    <h3 class="text-center text-primary mb-4">@ViewData["Title"]</h3>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success text-center">@TempData["Message"]</div>
    }

    <dl class="row">
        <dt class="col-sm-2">Mã đơn hàng</dt>
        <dd class="col-sm-10">@Model.Id</dd>
        <dt class="col-sm-2">Người mua</dt>
        <dd class="col-sm-10">@Model.User.UserName</dd>
        <dt class="col-sm-2">Ngày đặt</dt>
        <dd class="col-sm-10">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm:ss")</dd>
        <dt class="col-sm-2">Tổng tiền</dt>
        <dd class="col-sm-10">@Model.TotalPrice.ToString("N0") đ</dd>
        <dt class="col-sm-2">Trạng thái</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>

    <h5>Chi tiết đơn hàng</h5>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var detail in Model.OrderDetails)
            {
                <tr>
                    <td>@detail.Product.Name</td>
                    <td>@detail.UnitPrice.ToString("N0") đ</td>
                    <td>@detail.Quantity</td>
                    <td>@((detail.UnitPrice * detail.Quantity).ToString("N0")) đ</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-center">
        <a asp-action="Index" class="btn btn-secondary">Quay lại sản phẩm</a>
    </div>
</div>