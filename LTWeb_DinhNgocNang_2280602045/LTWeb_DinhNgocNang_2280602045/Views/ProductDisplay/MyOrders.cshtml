@model IEnumerable<LTWeb_DinhNgocNang_2280602045.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container mt-5">
    <h3 class="text-center text-primary mb-4">@ViewData["Title"]</h3>

    @if (!Model.Any())
    {
        <p class="text-center">Bạn chưa có đơn hàng nào.</p>
        <div class="text-center">
            <a asp-action="Index" class="btn btn-primary">Mua sắm ngay</a>
        </div>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Mã đơn hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@order.TotalPrice.ToString("N0") đ</td>
                        <td>@order.Status</td>
                        <td>
                            <a asp-action="Invoice" asp-route-id="@order.Id" class="btn btn-info btn-sm">Xem chi tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>