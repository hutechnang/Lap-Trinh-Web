@model List<LTWeb_DinhNgocNang_2280602045.Models.OrderCheckoutViewModel>

@{
    ViewData["Title"] = "Xác nhận thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isSinglePurchase = ViewBag.IsSinglePurchase ?? false;
}

<div class="container py-4">
    <h2>@ViewData["Title"]</h2>
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info" role="alert">
            @TempData["Message"]
        </div>
    }
    <div class="row">
        @if (Model == null || !Model.Any())
        {
            <p class="text-center">Không có sản phẩm để thanh toán.</p>
            <div class="text-center">
                <a asp-controller="ProductDisplay" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
            </div>
        }
        else
        {
            <form asp-action="CheckoutConfirmed" asp-controller="ShoppingCart" method="post">
                @Html.AntiForgeryToken()
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Hình ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><img src="@item.ProductImage" alt="@item.ProductName" class="img-fluid" style="max-height:200px;" /></td>
                                <td>@item.ProductName</td>
                                <td><strong>@item.ProductPrice.ToString("N0") ₫</strong></td>
                                <td>
                                    @if (!isSinglePurchase)
                                    {
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductId" value="@item.ProductId" />
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductName" value="@item.ProductName" />
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductPrice" value="@item.ProductPrice" />
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductImage" value="@item.ProductImage" />
                                        <input type="number" name="[@Model.IndexOf(item)].Quantity" value="@item.Quantity" min="1" class="form-control" style="width: 100px;" />
                                    }
                                    else
                                    {
                                        <span>@item.Quantity</span>
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductId" value="@item.ProductId" />
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductName" value="@item.ProductName" />
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductPrice" value="@item.ProductPrice" />
                                        <input type="hidden" name="[@Model.IndexOf(item)].ProductImage" value="@item.ProductImage" />
                                        <input type="hidden" name="[@Model.IndexOf(item)].Quantity" value="@item.Quantity" />
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="mb-3">
                    <label asp-for="@Model.First().ShippingAddress" class="form-label">Địa chỉ giao hàng</label>
                    <input asp-for="@Model.First().ShippingAddress" class="form-control" />
                    <span asp-validation-for="@Model.First().ShippingAddress" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="@Model.First().Note" class="form-label">Ghi chú</label>
                    <textarea asp-for="@Model.First().Note" class="form-control" rows="3" placeholder="Hãy nhập số điện thoại người nhận, số nhà(nếu có), tòa mấy chung cư(nếu có)"></textarea>
                    <span asp-validation-for="@Model.First().Note" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <strong>Tổng tiền: <span id="totalPrice">@Model.Sum(x => x.Quantity * x.ProductPrice).ToString("N0") ₫</span></strong>
                </div>
                <div class="text-end">
                    <button type="submit" class="btn btn-success">Thanh toán</button>
                    <a asp-controller="ProductDisplay" asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var quantityInputs = document.querySelectorAll('input[name$=".Quantity"]');
            var totalPriceSpan = document.getElementById('totalPrice');
            var prices = @Html.Raw(Json.Serialize(Model.Select(x => x.ProductPrice)));
            var noteTextarea = document.querySelector('textarea[name$=".Note"]');

            // Xóa placeholder khi focus và khôi phục khi blur nếu rỗng
            noteTextarea.addEventListener('focus', function () {
                if (this.value === this.placeholder) {
                    this.value = '';
                }
            });

            noteTextarea.addEventListener('blur', function () {
                if (this.value === '') {
                    this.value = this.placeholder;
                }
            });

            function updateTotal() {
                var total = 0;
                quantityInputs.forEach((input, index) => {
                    var qty = parseInt(input.value) || 1;
                    if (index < prices.length) {
                        total += qty * prices[index];
                    }
                });
                totalPriceSpan.textContent = total.toLocaleString('vi-VN') + ' ₫';
            }

            quantityInputs.forEach(input => input.addEventListener('input', updateTotal));
            updateTotal();
        });
    </script>
}