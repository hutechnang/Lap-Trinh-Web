@page
@model LTWeb_DinhNgocNang_2280602045.Areas.Identity.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Đăng xuất";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <form method="post" id="logoutForm">
            <p>Bạn có chắc chắn muốn đăng xuất?</p>
            <button type="button" onclick="confirmLogout(event)" class="btn btn-primary">Đăng xuất</button>
            <a asp-controller="ProductDisplay" asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function confirmLogout(e) {
            e.preventDefault();
            Swal.fire({
                title: 'Bạn có muốn đăng xuất?',
                text: "Bạn sẽ được chuyển hướng đến trang đăng ký sau khi đăng xuất!",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('logoutForm').submit();
                }
            });
        }
    </script>
}