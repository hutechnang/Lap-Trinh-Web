@model LTWeb_DinhNgocNang_2280602045.Models.Product

<h3>Chỉnh sửa sản phẩm</h3>

<form asp-action="Update" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Price">Giá sản phẩm</label>
        <input asp-for="Price" class="form-control" step="0.01" data-val-number="Giá phải là một số hợp lệ" data-val-range-min="0.01" data-val-range-max="1000000000"
               data-val-range="Giá phải nằm trong khoảng từ 0.01 đến 10000"
               value="@Model.Price.ToString("F2").Replace(",00", "")" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId">Loại sản phẩm</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name", Model.CategoryId))">
            <option value="">Chọn danh mục</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ImageUrl">Ảnh chính</label>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="Ảnh chính" style="max-width: 200px;" />
        }
        <input type="file" name="imageUrl" class="form-control" />
    </div>

    <div class="form-group">
        <label>Hình ảnh bổ sung</label>
        @if (Model.Images != null && Model.Images.Any())
        {
            <h4>Ảnh hiện tại</h4>
            @for (int i = 0; i < Model.Images.Count; i++)
            {
                <div>
                    <img src="@Model.Images[i].Url" alt="Ảnh bổ sung" style="max-width: 100px;" />
                    <input type="checkbox" name="keepImages[@i]" value="@Model.Images[i].Id" checked />
                    <label>Giữ ảnh này</label>
                </div>
            }
        }
        <label>Thêm ảnh mới</label>
        <input type="file" name="additionalImages" multiple class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
