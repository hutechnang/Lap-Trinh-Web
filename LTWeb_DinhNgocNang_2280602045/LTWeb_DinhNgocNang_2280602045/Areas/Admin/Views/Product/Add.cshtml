@model LTWeb_DinhNgocNang_2280602045.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg rounded">
                <div class="card-header bg-primary text-white text-center">
                    <h3>@ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Add" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" class="form-control" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Danh mục</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ảnh chính</label>
                            <input type="file" name="imageUrl" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Hình ảnh bổ sung</label>
                            <input type="file" name="additionalImages" multiple class="form-control" />
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-success px-5">Thêm sản phẩm</button>
                            <a href="@Url.Action("Index", "Product")" class="btn btn-secondary">Quay lại Danh sách</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>