@model IEnumerable<LTWeb_DinhNgocNang_2280602045.Models.Category>

@{
    ViewData["Title"] = "Danh sách danh mục";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Tạo mới danh mục</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Tên danh mục</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td>
                    <a class="btn btn-info" asp-action="Invoice" asp-route-id="@category.Id">Chi tiết</a>
                    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@category.Id">Sửa</a>
                    <a class="btn btn-danger" asp-action="Delete" asp-route-id="@category.Id">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
